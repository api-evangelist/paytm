      "item": [
        {
          "id": "757d25d5-2cec-424e-8959-34e887e6e773",
          "name": "Initiate transaction",
          "request": {
            "name": "Initiate transaction",
            "description": {
              "content": "Creates a transaction at Paytm and returns a txnToken (valid 15 minutes) that the merchant uses to invoke the checkout SDK or call processTransaction.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "theia",
                "api",
                "v1",
                "initiateTransaction"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "mid",
                  "value": "<string>",
                  "description": "(Required) Merchant ID issued by Paytm."
                },
                {
                  "disabled": false,
                  "key": "orderId",
                  "value": "<string>",
                  "description": "(Required) Merchant-generated unique order id (max 50 chars)."
                }
              ],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "{\n  \"head\": {\n    \"signature\": \"<string>\"\n  },\n  \"body\": {\n    \"requestType\": \"<string>\",\n    \"mid\": \"<string>\",\n    \"orderId\": \"<string>\",\n    \"txnAmount\": {\n      \"value\": \"<string>\",\n      \"currency\": \"<string>\"\n    },\n    \"userInfo\": {\n      \"custId\": \"<string>\"\n    },\n    \"websiteName\": \"<string>\",\n    \"callbackUrl\": \"<string>\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [
            {
              "id": "3787fea2-9dd3-4d37-885b-340e75abf5f7",
              "name": "Transaction initiated; response contains body.txnToken.",
              "originalRequest": {
                "url": {
                  "path": [
                    "theia",
                    "api",
                    "v1",
                    "initiateTransaction"
                  ],
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "query": [
                    {
                      "key": "mid",
                      "value": "<string>"
                    },
                    {
                      "key": "orderId",
                      "value": "<string>"
                    }
                  ],
                  "variable": []
                },
                "method": "POST",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"head\": {\n    \"signature\": \"<string>\"\n  },\n  \"body\": {\n    \"requestType\": \"Payment\",\n    \"mid\": \"<string>\",\n    \"orderId\": \"<string>\",\n    \"txnAmount\": {\n      \"value\": \"<string>\",\n      \"currency\": \"INR\"\n    },\n    \"userInfo\": {\n      \"custId\": \"<string>\"\n    },\n    \"websiteName\": \"<string>\",\n    \"callbackUrl\": \"<string>\"\n  }\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                }
              },
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "text/plain"
                }
              ],
              "body": "",
              "cookie": [],
              "_postman_previewlanguage": "text"
            }
          ],
          "event": [],
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          }
        },
        {
          "id": "ef2fc3a2-1be8-4d8e-b9a0-76e8615d5c98",
          "name": "Process transaction",
          "request": {
            "name": "Process transaction",
            "description": {
              "content": "Processes a transaction for the selected payment mode. Requires the txnToken from initiateTransaction in the request header.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "theia",
                "api",
                "v1",
                "processTransaction"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "mid",
                  "value": "<string>",
                  "description": "(Required) "
                },
                {
                  "disabled": false,
                  "key": "orderId",
                  "value": "<string>",
                  "description": "(Required) "
                }
              ],
              "variable": []
            },
            "header": [
              {
                "disabled": false,
                "description": "(Required) 15-minute-lived txnToken from initiateTransaction.",
                "key": "txnToken",
                "value": "<string>"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "{\n  \"head\": {\n    \"signature\": \"<string>\"\n  },\n  \"body\": {\n    \"mid\": \"<string>\",\n    \"orderId\": \"<string>\",\n    \"paymentMode\": \"<string>\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [
            {
