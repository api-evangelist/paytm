  "info": {
    "_postman_id": "ad5bca09-a4e0-4280-8766-09d64434cd64",
    "name": "Paytm Payment Gateway API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Server-to-server REST APIs for Paytm Payment Gateway integrations. Covers transaction initiation (returning a txnToken used by checkout SDKs), transaction processing for selected payment modes, and refund initiation. Requests are signed via Paytm's checksum logic and the signature is sent in the request head.\n\nContact Support:\n Name: Paytm for Business",
      "type": "text/plain"
    }
  }
